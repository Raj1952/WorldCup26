# Tempo — World Cup 2026 Match Outcome Predictor
# Copy this file to .env and fill in your real values.
# .env is listed in .gitignore and must NEVER be committed.

# football-data.org free-tier API key (see §8 C2 in CLAUDE.md).
# Register at https://www.football-data.org/ to obtain your key.
# Without this key the system falls back to the openfootball JSON feed (no auth).
FOOTBALL_DATA_API_KEY=your_api_key_here

# Supermemory — persistent long-term memory for predictions and model events.
# Get your key at https://supermemory.ai
SUPERMEMORY_API_KEY=your_supermemory_key_here

# Optional: enable the retro goal Easter egg (default off). Set to "1" to enable.
# RETRO_GOAL_FX=0
