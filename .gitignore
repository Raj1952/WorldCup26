# Secrets — never commit
.env
.streamlit/secrets.toml

# Virtual environment
.venv/

# Raw data and large pipeline outputs
data/raw/
data/tempo.db

# Model artifacts
artifacts/models/*.pkl
artifacts/models/*.joblib
artifacts/models/*.json
artifacts/models/*.ubj
artifacts/reports/*.html

# Python caches
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# Pipeline output parquets are committed — the app and CI read them.
# Do NOT add predictions.parquet or artifacts/reports/*.parquet here.

# Claude Code / agent tooling — local only
.agents/
.claude/
skills-lock.json

# Streamlit runtime logs
.streamlit_err.txt
.streamlit_log.txt

# Temporary nav screenshots
desktop_nav.png
mobile_nav.png

# IDE / OS noise
.vscode/
.idea/
*.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb
